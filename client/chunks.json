1 rounded-full text-[11px] font-bold tracking-wide uppercase ${statusInfo.color}`}>\n                        {statusInfo.label}\n                      </span>\n                    </td>\n                    <td className=\"px-6 py-4 text-right\">\n                      <div className=\"relative inline-block text-left group/menu\">\n                        <button className=\"p-1.5 text-gray-400 hover:text-gray-900 hover:bg-gray-200 rounded-lg transition-colors focus:outline-none\">\n                          <MoreHorizontal size={18} />\n                        </button>\n                        <div className=\"absolute right-0 mt-1 w-36 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-20 overflow-hidden transform origin-top-right scale-95 group-hover/menu:scale-100\">\n                          <div className=\"py-1\">\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Eye size={14} /> View\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Edit size={14} /> Edit\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <FileText size={14} /> Invoice\n                            </button>\n                            <div className=\"border-t border-gray-100 my-1\"></div>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2 font-bold\">\n                              <Trash2 size={14} /> Delete\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    </td>\n                  </tr>\n                );\n              })}\n            </tbody>\n          </table>\n        </div>\n        \n        {/* Pagination */}\n        <div className=\"p-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50/50\">\n          <span className=\"text-sm text-gray-500 font-medium\">Showing <span className=\"font-bold text-gray-900\">1</span> to <span className=\"font-bold text-gray-900\">{recentOrders.length}</span> of <span className=\"font-bold text-gray-900\">248</span> results</span>\n          <div className=\"flex items-center gap-1\">\n            <button className=\"p-1.5 border border-gray-200 rounded-lg text-gray-400 bg-white disabled:opacity-50 transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.05)] cursor-not-allowed\" disabled>\n              <ChevronLeft size={16} />\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg bg-blue-600 text-white font-bold text-sm shadow-[0_2px_8px_rgba(37,99,235,0.3)]\">\n              1\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 font-bold text-sm hover:bg-gray-200 transition-colors\">\n              2\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 font-bold text-sm hover:bg-gray-200 transition-colors\">\n              3\n            </button>\n            <span className=\"px-1 text-gray-400\">...</span>\n            <button className=\"p-1.5 border border-gray-200 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.05)] bg-white cursor-pointer\">\n              <ChevronRight size={16} />\n            </button>\n          </div>\n        </div>\n      </Card>",
  "      <div className=\"grid grid-cols-1 xl:grid-cols-3 gap-6 mt-2\">\n        <div className=\"xl:col-span-2\">\n          {/* Top Selling Products */}\n          <Card className=\"flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.04)] border-gray-100 h-full\">\n            <div className=\"p-5 border-b border-gray-100 bg-white sticky top-0 z-10 rounded-t-xl flex items-center justify-between\">\n              <div>\n                <h3 className=\"font-bold text-gray-900 text-lg\">S\u1ea3n ph\u1ea9m b\u00e1n ch\u1ea1y</h3>\n                <p className=\"text-sm text-gray-500 mt-1\">Top s\u1ea3n ph\u1ea9m mang l\u1ea1i doanh thu cao nh\u1ea5t</p>\n              </div>\n              <button className=\"text-sm font-semibold text-blue-600 hover:underline\">Xem t\u1ea5t c\u1ea3</button>\n            </div>\n            <div className=\"p-0 overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse whitespace-nowrap\">\n                <thead className=\"bg-gray-50/50\">\n                  <tr className=\"text-gray-500 text-xs font-bold uppercase tracking-wider\">\n                    <th className=\"px-6 py-4\">S\u1ea3n ph\u1ea9m</th>\n                    <th className=\"px-6 py-4\">Doanh s\u1ed1</th>\n                    <th className=\"px-6 py-4\">Doanh thu</th>\n                    <th className=\"px-6 py-4\">Ch\u1ec9 ti\u00eau</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-gray-100\">\n                  {[\n                    { id: 1, name: \"iPhone 15 Pro Max 256GB\", category: \"\u0110i\u1ec7n tho\u1ea1i\", sales: 1245, revenue: 35987000000, progress: 85, trend: \"+12.5%\", img: \"1696446700704-46c3e3e55a51\" },\n                    { id: 2, name: \"MacBook Pro 14\\\" M3 Pro\", category: \"Laptop\", sales: 856, revenue: 45359000000, progress: 65, trend: \"+8.2%\", img: \"1517336714731-489689fd1ca8\" },\n                    { id: 3, name: \"Samsung Galaxy S24 Ultra\", category: \"\u0110i\u1ec7n tho\u1ea1i\", sales: 743, revenue: 23768000000, progress: 55, trend: \"-2.4%\", img: \"1610945415295-d9bbf067e59c\" },\n                    { id: 4, name: \"Sony WH-1000XM5\", category: \"Tai nghe\", sales: 521, revenue: 3902000000, progress: 40, trend: \"+15.3%\", img: \"1505740420928-5e560c06d30e\" },\n                    { id: 5, name: \"iPad Pro 12.9\\\" M2\", category: \"M\u00e1y t\u00ednh b\u1ea3ng\", sales: 342, revenue: 9572000000, progress: 25, trend: \"+5.1%\", img: \"1544244015-0df4b3ffc6b0\" },\n                  ].map((prod, idx) => {\n                    const isPositive = prod.trend.startsWith(\"+\");\n                    return (\n                      <tr key={prod.id} className=\"hover:bg-gray-50 transition-colors group\">\n                        <td className=\"px-6 py-4\">\n                          <div className=\"flex items-center gap-4\">\n                            <div className=\"relative\">\n                              <img src={img(prod.img, 100, 100)} alt={prod.name} className=\"w-12 h-12 rounded-xl object-cover border border-gray-100 shadow-sm group-hover:scale-110 transition-transform\" />\n                              {idx === 0 && (\n                                <div className=\"absolute -top-2 -right-2 w-6 h-6 bg-amber-400 rounded-full flex items-center justify-center border-2 border-white shadow-sm z-10\" title=\"Top Seller\">\n                                  <Crown size={12} className=\"text-white\" strokeWidth={3} />\n                                </div>\n                              )}\n                            </div>\n                            <div>\n                              <div className=\"font-bold text-gray-900 text-sm group-hover:text-blue-600 transition-colors cursor-pointer\">{prod.name}</div>\n                              <div className=\"text-xs text-gray-500 font-medium\">{prod.category}</div>\n                            </div>\n                          </div>\n                        </td>\n                        <td className=\"px-6 py-4\">\n                          <div className=\"flex flex-col gap-1\">\n                            <span className=\"font-bold text-gray-900\">{fmt(prod.sales).replace('\u20ab', '')}</span>\n                            <span className={`text-[11px] font-bold flex items-center gap-0.5 ${isPositive ? 'text-emerald-600' : 'text-red-600'}`}>\n                              {isPositive ? <TrendingUp size={12}/> : <TrendingDown size={12}/>}\n                              {prod.trend}\n                            </span>\n                          </div>\n                        </td>\n                        <td className=\"px-6 py-4\">\n                          <span className=\"font-bold text-blue-600 bg-blue-50 px-2.5 py-1.5 rounded-lg text-sm\">{fmt(prod.revenue)}</span>\n                        </td>\n                        <td className=\"px-6 py-4 w-[200px]\">\n                          <div className=\"flex items-center gap-3\">\n                            <div className=\"flex-1 h-2 bg-gray-100 rounded-full overflow-hidden\">\n                              <div className=\"h-full bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full relative overflow-hidden\" style={{ width: `${prod.progress}%` }}>\n                                <div className=\"absolute inset-0 bg-white/20 w-full animate-[shimmer_2s_infinite]\"></div>\n                              </div>\n                            </div>\n                            <span className=\"text-xs font-bold text-gray-700 w-8\">{prod.progress}%</span>\n                          </div>\n                        </td>\n                      </tr>\n                    );\n                  })}\n                </tbody>\n              </table>\n            </div>\n          </Card>\n        </div>",
