[
  "      {/* Recent Orders Table */}\n      <Card className=\"overflow-hidden flex flex-col shadow-[0_8px_30px_rgb(0,0,0,0.04)] border-gray-100 mt-2\">\n        <div className=\"p-5 border-b border-gray-100 flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white\">\n          <div>\n            <h3 className=\"font-bold text-gray-900 text-lg\">\u0110\u01a1n h\u00e0ng g\u1ea7n \u0111\u00e2y</h3>\n            <p className=\"text-sm text-gray-500 mt-1\">Danh s\u00e1ch c\u00e1c giao d\u1ecbch m\u1edbi nh\u1ea5t c\u1ea7n x\u1eed l\u00fd</p>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <div className=\"relative\">\n              <Search size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" />\n              <input \n                type=\"text\" \n                placeholder=\"T\u00ecm ki\u1ebfm \u0111\u01a1n h\u00e0ng...\" \n                className=\"pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 w-full md:w-64 transition-all\"\n              />\n            </div>\n            <button className=\"flex items-center gap-2 px-3 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm\">\n              <Filter size={16} />\n              <span className=\"hidden sm:inline\">B\u1ed9 l\u1ecdc</span>\n            </button>\n          </div>\n        </div>\n\n        <div className=\"overflow-x-auto min-h-[300px]\">\n          <table className=\"w-full text-left border-collapse whitespace-nowrap relative\">\n            <thead className=\"sticky top-0 z-10 bg-gray-50/95 backdrop-blur-sm shadow-[0_1px_2px_rgba(0,0,0,0.02)]\">\n              <tr className=\"text-gray-500 text-xs font-bold uppercase tracking-wider\">\n                <th className=\"px-6 py-4 cursor-pointer hover:text-gray-900 transition-colors group\">\n                  <div className=\"f