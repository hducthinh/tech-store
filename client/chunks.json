               <div className=\"flex items-center gap-1\">M\u00e3 \u0110\u01a1n <ArrowUpDown size={12} className=\"opacity-0 group-hover:opacity-100 transition-opacity\" /></div>\n                </th>\n                <th className=\"px-6 py-4 cursor-pointer hover:text-gray-900 transition-colors group\">\n                  <div className=\"flex items-center gap-1\">Kh\u00e1ch h\u00e0ng <ArrowUpDown size={12} className=\"opacity-0 group-hover:opacity-100 transition-opacity\" /></div>\n                </th>\n                <th className=\"px-6 py-4 cursor-pointer hover:text-gray-900 transition-colors group\">\n                  <div className=\"flex items-center gap-1\">Thanh to\u00e1n <ArrowUpDown size={12} className=\"opacity-0 group-hover:opacity-100 transition-opacity\" /></div>\n                </th>\n                <th className=\"px-6 py-4 cursor-pointer hover:text-gray-900 transition-colors group\">\n                  <div className=\"flex items-center gap-1\">T\u1ed5ng ti\u1ec1n <ArrowUpDown size={12} className=\"opacity-0 group-hover:opacity-100 transition-opacity\" /></div>\n                </th>\n                <th className=\"px-6 py-4 cursor-pointer hover:text-gray-900 transition-colors group\">\n                  <div className=\"flex items-center gap-1\">Tr\u1ea1ng th\u00e1i <ArrowUpDown size={12} className=\"opacity-0 group-hover:opacity-100 transition-opacity\" /></div>\n                </th>\n                <th className=\"px-6 py-4 text-right\">Thao t\u00e1c</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-gray-100\">\n              {recentOrders.map((o) => {\n                const statusInfo = getStatusLabel(o.status);\n                const paymentInfo = getPaymentLabel(o.paymentMethod);\n                const name = o.shippingAddress?.fullName || o.userId?.fullName || \"Kh\u00e1ch V\u00e3ng Lai\";\n                const email = o.userId?.email || \"No email provided\";\n                const avatar = name.charAt(0).toUpperCase();\n\n                return (\n                  <tr key={o._id} className=\"hover:bg-blue-50/40 even:bg-gray-50/50 transition-colors group\">\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex items-center gap-2\">\n                        <span className=\"text-sm font-bold text-gray-900\">#{o._id.substring(0, 8).toUpperCase()}</span>\n                        <button className=\"text-gray-400 hover:text-blue-600 transition-colors opacity-0 group-hover:opacity-100\">\n                          <Copy size={14} />\n                        </button>\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"w-9 h-9 rounded-full bg-gradient-to-tr from-blue-100 to-indigo-100 flex items-center justify-center shrink-0 border border-blue-200\">\n                          <span className=\"text-blue-700 font-bold text-sm\">{avatar}</span>\n                        </div>\n                        <div>\n                          <div className=\"text-sm font-bold text-gray-900\">{name}</div>\n                          <div className=\"text-xs text-gray-500 font-medium\">{email}</div>\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className=\"inline-flex items-center px-2 py-1 bg-gray-100 text-gray-700 rounded-md text-xs font-semibold\">\n                        {paymentInfo.icon} {paymentInfo.label}\n                      </span>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className=\"text-sm font-black text-gray-900\">{fmt(o.totalAmount)}</span>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className={`inline-flex items-center justify-center px-3 h-7 rounded-full text-xs font-medium ${statusInfo.color}`}>\n                        {statusInfo.icon}\n                        {statusInfo.label}\n                      </span>\n                    </td>\n                    <td className=\"px-6 py-4 text-right\">\n                      <div className=\"relative inline-block text-left group/menu\">\n                        <button className=\"p-1.5 text-gray-400 hover:text-gray-900 hover:bg-gray-200 rounded-lg transition-colors focus:outline-none\">\n                          <MoreHorizontal size={18} />\n                        </button>\n                        <div className=\"absolute right-0 mt-1 w-36 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-20 overflow-hidden transform origin-top-right scale-95 group-hover/menu:scale-100\">\n                          <div className=\"py-1\">\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Eye size={14} /> View\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Edit size={14} /> Edit\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <FileText size={14} /> Invoice\n                            </button>\n                            <div className=\"border-t border-gray-100 my-1\"></div>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2 font-bold\">\n                              <Trash2 size={14} /> Delete\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    </td>\n                  </tr>\n                );\n              })}\n            </tbody>\n          </table>\n        </div>\n        \n        {/* Pagination */}\n        <div className=\"p-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50/50\">\n          <span className=\"text-sm text-gray-500 font-medium\">Showing <span className=\"font-bold text-gray-900\">1</span> to <span className=\"font-bold text-gray-900\">{recentOrders.length}</span> of <span className=\"font-bold text-gray-900\">248</span> results</span>\n          <div className=\"flex items-center gap-1\">\n            <button className=\"p-1.5 border border-gray-200 rounded-lg text-gray-400 bg-white disabled:opacity-50 transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.05)] cursor-not-allowed\" disabled>\n              <ChevronLeft size={16} />\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg bg-blue-600 text-white font-bold text-sm shadow-[0_2px_8px_rgba(37,99,235,0.3)]\">\n              1\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 font-bold text-sm hover:bg-gray-200 transition-colors\">\n              2\n            </button>\n            <button className=\"w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 font-bold text-sm hover:bg-gray-200 transition-colors\">\n              3\n            </button>\n            <span className=\"px-1 text-gray-400\">...</span>\n            <button className=\"p-1.5 border border-gray-200 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.05)] bg-white cursor-pointer\">\n              <ChevronRight size={16} />\n            </button>\n          </div>\n        </div>\n      </Card>\n    </div>\n  );\n}",
  "              {recentOrders.length > 0 ? recentOrders.map((o) => {\n                const statusInfo = getStatusLabel(o.status);\n                const paymentInfo = getPaymentLabel(o.paymentMethod);\n                const name = o.shippingAddress?.fullName || o.userId?.fullName || \"Kh\u00e1ch V\u00e3ng Lai\";\n                const email = o.userId?.email || \"No email provided\";\n                const avatar = name.charAt(0).toUpperCase();\n\n                return (\n                  <tr key={o._id} className=\"hover:bg-blue-50/40 even:bg-gray-50/50 transition-colors group\">\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex flex-col gap-1\">\n                        <div className=\"flex items-center gap-2\">\n                          <span className=\"text-sm font-bold text-gray-900\">#{o._id.substring(0, 8).toUpperCase()}</span>\n                          <button className=\"text-gray-400 hover:text-blue-600 transition-colors opacity-0 group-hover:opacity-100\">\n                            <Copy size={14} />\n                          </button>\n                        </div>\n                        <div className=\"text-xs text-gray-500 font-medium\">\n                          {new Date(o.createdAt).toLocaleDateString('vi-VN', { \n                            day: '2-digit', month: '2-digit', year: 'numeric', \n                            hour: '2-digit', minute: '2-digit' \n                          })}\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"w-9 h-9 rounded-full bg-gradient-to-tr from-blue-100 to-indigo-100 flex items-center justify-center shrink-0 border border-blue-200\">\n                          <span className=\"text-blue-700 font-bold text-sm\">{avatar}</span>\n                        </div>\n                        <div>\n                          <div className=\"text-sm font-bold text-gray-900\">{name}</div>\n                          <div className=\"text-xs text-gray-500 font-medium\">{email}</div>\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className=\"inline-flex items-center px-2 py-1 bg-gray-100 text-gray-700 rounded-md text-xs font-semibold\">\n                        {paymentInfo.icon} {paymentInfo.label}\n                      </span>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className=\"text-sm font-black text-gray-900\">{fmt(o.totalAmount)}</span>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <span className={`inline-flex items-center justify-center px-3 h-7 rounded-full text-xs font-medium ${statusInfo.color}`}>\n                        {statusInfo.icon}\n                        {statusInfo.label}\n                      </span>\n                    </td>\n                    <td className=\"px-6 py-4 text-right\">\n                      <div className=\"relative inline-block text-left group/menu\">\n                        <button className=\"p-1.5 text-gray-400 hover:text-gray-900 hover:bg-gray-200 rounded-lg transition-colors focus:outline-none\">\n                          <MoreHorizontal size={18} />\n                        </button>\n                        <div className=\"absolute right-0 mt-1 w-36 bg-white rounded-2xl shadow-lg border border-gray-100 opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-20 overflow-hidden transform origin-top-right scale-95 group-hover/menu:scale-100\">\n                          <div className=\"py-1\">\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Eye size={14} /> View\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <Edit size={14} /> Edit\n                            </button>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 flex items-center gap-2 font-medium\">\n                              <FileText size={14} /> Invoice\n                            </button>\n                            <div className=\"border-t border-gray-100 my-1\"></div>\n                            <button className=\"w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2 font-bold\">\n                              <Trash2 size={14} /> Delete\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    </td>\n                  </tr>\n                );\n              }) : (\n                <tr>\n                  <td colSpan=\"6\" className=\"px-6 py-8 text-center text-gray-500 text-sm font-medium\">\n                    Ch\u01b0a c\u00f3 \u0111\u01a1n h\u00e0ng n\u00e0o g\u1ea7n \u0111\u00e2y\n                  </td>\n                </tr>\n              )}"
]